# =====================================================================
# Config LOCAL (NÃO versionada) — valores reais do ambiente do Jorge.
# Copie para convert2nc.env e ajuste o que precisar. É lida (source) por:
#   - converte_periodo.sh  (conversão INTERATIVA por período — use p/ /oper)
#   - roda_convert2nc.pbs   (batch nos nós — só se os dados forem visíveis neles)
#   - roda_merge2nc.sh      (MERGE/GPM — usa CONDA_ENV daqui)
#
#   cp convert2nc.env.example convert2nc.env
#   # edite convert2nc.env  (nunca edite os .pbs/.sh versionados)
#
# OBS: /oper NÃO é visível dos nós de processamento -> para dados em /oper use
#      o converte_periodo.sh (interativo), NÃO o qsub.
# =====================================================================

# --- ambiente Python (conda; obrigatório p/ GRIB2/eccodes, Python >= 3.8) ---
CONDA_ENV="/p/projetos/grpeta/Team/jorge.gomes/conda/envs/convert2nc"
CONDA_SH="/p/app/anaconda/etc/profile.d/conda.sh"
# VENV="~/venvs/convert2nc"        # alternativa (só serve p/ FORMATO=bin)

# --- variáveis e GRIB2 (comum a todos) ---
FORMATO="grib2"                  # "bin" ou "grib2"
GRIB_ENGINE="cfgrib"             # cfgrib = eccodes (padrão, sem wgrib2)
VARS="acpcp"                     # nomes do eccodes; veja: convert2nc.py <ctl> --grib --list-vars
GRIB_ASNAME="PREC"               # renomeia a saída (só com 1 variável em VARS!)
COMPLEVEL=1

# =====================================================================
# converte_periodo.sh  — conversão INTERATIVA por período (Eta em /oper)
#   bash converte_periodo.sh 2026010100 2026033100
# =====================================================================
BASE="/oper/dados/modelo/eta/ams_08km/brutos"   # + /AAAA/MM/DD/HH/ é montado sozinho
CTLTPL="Eta_ams_08km_%INIT%.ctl"                # %INIT% = AAAAMMDDHH
OUTROOT="./nc"                                  # saída: OUTROOT/AAAAMMDDHH/
STEP_H="12"                                     # 12 = rodadas 00 e 12 UTC; 24 = só 00Z
JOBS="4"                                        # conversões simultâneas (login: modesto)
# período padrão (pode passar na linha de comando em vez daqui):
INIT_FROM="2026010100"
INIT_TO="2026033100"

# =====================================================================
# roda_convert2nc.pbs  — batch nos nós (SÓ se os dados forem vistos nos nós)
# =====================================================================
MODE="batch"                     # "single" ou "batch"
NCORES=256
# MODE=single:
CTL="/oper/dados/modelo/eta/ams_08km/brutos/2026/01/01/00/Eta_ams_08km_2026010100.ctl"
OUTDIR="."
# MODE=batch:
CTL_GLOB="/oper/dados/modelo/eta/ams_08km/brutos/2026/*/*/*/Eta_ams_08km_*.ctl"
JOBS_PER_FILE="8"
